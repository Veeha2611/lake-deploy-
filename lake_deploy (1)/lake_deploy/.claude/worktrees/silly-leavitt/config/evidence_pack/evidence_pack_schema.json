{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidencePack",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "generated_at": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "unavailable", "inconclusive"] },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "executed_sql": { "type": ["string", "null"] },
    "query_execution_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true
    },
    "cross_checks": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["status", "sources"]
}

