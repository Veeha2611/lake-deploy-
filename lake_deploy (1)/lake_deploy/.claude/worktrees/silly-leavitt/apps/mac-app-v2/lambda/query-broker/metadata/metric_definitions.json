{
  "version": "2026-02-11",
  "metrics": {
    "total_mrr": {
      "description": "Total MRR (latest month) with YTD/TTM context.",
      "query_id": "mrr_overview",
      "value_column": "latest_total_mrr",
      "source_views": [
        "curated_core.v_platt_billing_mrr_monthly"
      ],
      "cross_check_query_ids": [
        "executive_strip_mrr"
      ],
      "sanity_query_id": "mrr_trend_12m",
      "driver_query_ids": [
        "mrr_trend_12m"
      ],
      "default_time_window": {
        "type": "last_n",
        "unit": "month",
        "n": 12
      }
    },
    "mrr_trend_12m": {
      "description": "MRR trend for the last 12 months.",
      "query_id": "mrr_trend_12m",
      "value_column": "total_mrr",
      "source_views": [
        "curated_core.v_platt_billing_mrr_monthly"
      ],
      "default_time_window": {
        "type": "last_n",
        "unit": "month",
        "n": 12
      }
    },
    "arpu": {
      "description": "Average revenue per user (latest month).",
      "query_id": "arpu_overview",
      "value_column": "latest_arpu",
      "source_views": [
        "curated_core.v_platt_billing_mrr_monthly"
      ],
      "cross_check_query_ids": [
        "mrr_overview"
      ],
      "default_time_window": {
        "type": "last_n",
        "unit": "month",
        "n": 12
      }
    },
    "active_customers": {
      "description": "Customer identity overview (billing, services, subscriptions, SSOT).",
      "query_id": "customer_identity_overview",
      "value_column": "billing_customers",
      "source_views": [
        "curated_core.v_platt_billing_customer_month_latest",
        "curated_core.dim_customer_platt_v1_1",
        "curated_core.platt_customer_current_ssot",
        "curated_recon.v_network_mix_billing_aligned_latest"
      ],
      "cross_check_query_ids": [
        "active_accounts"
      ],
      "default_time_window": {
        "type": "latest"
      }
    },
    "customer_identity": {
      "description": "Customer identity overview (billing, services, subscriptions, SSOT).",
      "query_id": "customer_identity_overview",
      "value_column": "billing_customers",
      "source_views": [
        "curated_core.v_platt_billing_customer_month_latest",
        "curated_core.dim_customer_platt_v1_1",
        "curated_core.platt_customer_current_ssot",
        "curated_recon.v_network_mix_billing_aligned_latest"
      ],
      "default_time_window": {
        "type": "latest"
      }
    },
    "total_customers": {
      "description": "Total customers from SSOT snapshot.",
      "query_id": "customer_overview",
      "value_column": "total_customers_ssot",
      "source_views": [
        "curated_core.platt_customer_current_ssot"
      ],
      "default_time_window": {
        "type": "snapshot"
      }
    },
    "customers_by_city": {
      "description": "Customers grouped by city (active, SSOT).",
      "compile": {
        "source_view": "curated_core.platt_customer_current_ssot",
        "metric_alias": "customer_count",
        "measure_expr": "COUNT(DISTINCT username)",
        "default_dimensions": [
          "gwi_lq_city"
        ],
        "default_filters": [
          {
            "field": "sensitive_p",
            "op": "!=",
            "value": "y"
          },
          {
            "field": "active",
            "op": "in",
            "value": [
              "y",
              "yes",
              "true",
              "1"
            ]
          }
        ]
      }
    },
  "customers_in_city": {
    "description": "Customers in a specified city (active, SSOT).",
    "query_id": "customers_in_city_breakdown",
    "value_column": "total_customers",
    "auto_verify": false,
    "system_compare_query_ids": [
      {
        "query_id": "customers_in_city_breakdown",
        "value_column": "total_customers",
        "label": "SSOT city total customers"
      },
      {
        "query_id": "customers_in_city_breakdown",
        "value_column": "active_customers",
        "label": "SSOT city active customers"
      },
      {
        "query_id": "platt_billing_customers_by_system_latest",
        "value_column": "plat_id_count",
        "label": "Billing customers (MRR>0) by system"
      },
      {
        "query_id": "plat_id_count_by_network_latest",
        "value_column": "plat_id_count",
        "label": "Investor billed customers (snapshot)"
      },
      {
        "query_id": "billing_customers_in_network_latest",
        "value_column": "billed_customers",
        "label": "Billed customers (network-mapped)"
      }
    ],
    "source_views": [
      "curated_core.platt_customer_current_ssot",
      "curated_core.v_monthly_mrr_platt",
      "curated_recon.platt_customer_system_map",
      "curated_recon.gwi_system_network_map",
      "curated_core.v_investor_revenue_mix_latest"
    ],
    "compile": {
      "source_view": "curated_core.platt_customer_current_ssot",
      "metric_alias": "customer_count",
      "measure_expr": "COUNT(DISTINCT username)",
        "default_dimensions": [],
        "default_filters": [
          {
            "field": "sensitive_p",
            "op": "!=",
            "value": "y"
          },
          {
            "field": "active",
            "op": "in",
            "value": [
              "y",
              "yes",
              "true",
              "1"
            ]
          }
        ]
      }
    },
    "copper_customers": {
      "description": "Copper customers from modeled network health + investor billing mix.",
      "query_id": "copper_customers_count",
      "value_column": "copper_customer_count",
      "auto_verify": false,
      "system_compare_query_ids": [
        {
          "query_id": "copper_customers_count",
          "value_column": "copper_customer_count",
          "label": "Investor billed copper customers"
        },
        {
          "query_id": "copper_customers_network_mix",
          "value_column": "copper_billed_customers",
          "label": "Investor billed copper customers (latest snapshot)"
        },
        {
          "query_id": "copper_customers_network_mix",
          "value_column": "copper_active_services",
          "label": "Modeled active copper services (latest dt)"
        }
      ],
      "source_views": [
        "curated_core.v_network_health",
        "curated_core.v_investor_revenue_mix_latest"
      ],
      "default_time_window": {
        "type": "snapshot"
      }
    },
    "passings_subscribers": {
